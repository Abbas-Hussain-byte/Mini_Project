# Auto detect text files and perform LF normalization
* text=auto

# Code files should be LF on checkout/commit to ensure consistency across OSes
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.py text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Windows specific files
*.bat text eol=crlf
